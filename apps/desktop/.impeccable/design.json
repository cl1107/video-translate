  "narrative": {
    "northStar": "The Quiet Workbench",
    "overview": "桌面端是安静工作台：中性、可扫读、密度服务任务。视觉来自 shadcn/ui New York + neutral 基底，用 OKLCH 中性斜坡支撑锋利·现代·自信。深度几乎只靠边框与轻阴影。",
    "keyCharacteristics": [
      "中性 OKLCH 斜坡；主色近黑墨色",
      "任务优先：上传 / 任务 / 设置",
      "扁平分层，无戏剧 elevation",
      "系统字体；text-sm / text-base 为主",
      "支持 .dark 语义反转"
    ],
    "rules": [
      {
        "name": "The Ink-Not-Brand Rule",
        "body": "桌面主色是墨色中性，不是 landing 的酸绿。",
        "section": "colors"
      },
      {
        "name": "The Readable Muted Rule",
        "body": "muted-foreground 禁止再洗成更浅灰。",
        "section": "colors"
      },
      {
        "name": "The No-Hero-Type Rule",
        "body": "桌面禁止 marketing 级 clamp 大标题。",
        "section": "typography"
      },
      {
        "name": "The Flat-By-Default Rule",
        "body": "表面静止时几乎平坦；阴影只服务控件与卡片落差。",
        "section": "elevation"
      }
    ],
    "dos": [
      "Do 让每一屏主路径指向导入 → 处理 → 导出字幕。",
      "Do 用语义 token，而不是任意灰。",
      "Do 保持错误与依赖状态可行动。",
      "Do 尊重 prefers-reduced-motion。",
      "Do 文案短、准、中文优先。"
    ],
    "donts": [
      "Don't 通用 SaaS 仪表盘：紫渐变、万能卡片网格、空泛 AI 口号。",
      "Don't 企业级沉重后台。",
      "Don't 花哨 AI 演示站。",
      "Don't 廉价绿色科技感。",
      "Don't 把 landing 酸绿大面积搬进工具主色。",
      "Don't 侧边彩条、渐变文字、32px+ 夸张圆角卡片。"
