{
  "displayName": "视频翻译助手",
  "name": "video-translate",
  "description": "基于 sherpa-onnx（SenseVoice/Fun-ASR-Nano）+ Ollama 的本地视频翻译软件",
  "version": "0.2.0",
  "main": "./node_modules/.dev/main/index.js",
  "resources": "src/resources",
  "author": {
    "name": "Video Translate Team",
    "email": "contact@videotranslate.com"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "start": "electron-vite preview",
    "predev": "run-s clean:dev",
    "dev": "cross-env NODE_ENV=development electron-vite dev --watch",
    "compile:app": "electron-vite build",
    "compile:packageJSON": "tsx ./src/lib/electron-app/release/modules/prebuild.ts",
    "prebuild": "run-s clean:dev compile:app compile:packageJSON",
    "prepare:ffmpeg": "node scripts/prepare-bundled-ffmpeg.cjs",
    "build": "pnpm run prepare:ffmpeg && pnpm run rebuild:native && electron-builder",
    "build:bundled": "cross-env BUNDLE_FFMPEG=1 pnpm run build",
    "build:slim": "cross-env BUNDLE_FFMPEG=0 pnpm run build",
    "postinstall": "run-s prebuild rebuild:native",
    "install:deps": "electron-builder install-app-deps",
    "rebuild:native": "electron-rebuild --force --only better-sqlite3",
    "make:release": "tsx ./src/lib/electron-app/release/modules/release.ts",
    "release": "pnpm run build -- --publish always",
    "clean:dev": "rimraf ./node_modules/.dev",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint --no-errors-on-unmatched",
    "lint:fix": "biome lint --write --no-errors-on-unmatched",
    "test": "tsx --test src/main/electron-builder.test.ts src/main/utils/system-check.test.ts src/main/services/ffmpeg/processor.test.ts src/main/services/legacy-asr-removal.test.ts src/main/services/ollama/client.test.ts src/renderer/components/system/SystemCheckProgress.test.tsx",
    "test:system-check": "tsx --test src/main/utils/system-check.test.ts"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node-fetch": "^2.6.13",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "electron-router-dom": "^2.1.1",
    "lucide-react": "^0.577.0",
    "node-abi": "^4.33.0",
    "node-fetch": "^3.3.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "sherpa-onnx-node": "1.13.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@electron/rebuild": "^4.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.3",
    "code-inspector-plugin": "^1.6.6",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.6",
    "electron-builder-squirrel-windows": "26.15.6",
    "electron-extension-installer": "^1.2.0",
    "electron-vite": "6.0.0-beta.1",
    "npm-run-all": "^4.1.5",
    "open": "^11.0.0",
    "rimraf": "^6.1.3",
    "rollup-plugin-inject-process-env": "^1.3.1",
    "7zip-bin": "^5.2.0",
    "semver": "^7.8.5",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
